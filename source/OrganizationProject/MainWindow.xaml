<Window x:Class="OrganizationProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrganizationProject"
        mc:Ignorable="d"
        Title="" Height="700" Width="1050"
        Background="#0B1120" FontFamily="Segoe UI">

    <Window.Resources>
        <local:PriorityToColorConverter x:Key="PriorityToColorConverter"/>

        <!-- ── NEXUS-inspired Dark Palette ── -->
        <SolidColorBrush x:Key="PrimaryBrush"       Color="#6366F1"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush"  Color="#4F46E5"/>
        <SolidColorBrush x:Key="SidebarBgBrush"     Color="#0F172A"/>
        <SolidColorBrush x:Key="SidebarActiveBrush" Color="#312E81"/>
        <SolidColorBrush x:Key="SuccessBrush"       Color="#10B981"/>
        <SolidColorBrush x:Key="ErrorBrush"         Color="#EF4444"/>
        <SolidColorBrush x:Key="CardBrush"          Color="#1E293B"/>
        <SolidColorBrush x:Key="SurfaceBrush"       Color="#273348"/>
        <SolidColorBrush x:Key="BorderBrush2"       Color="#334155"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>

        <!-- ── Primary Button ── -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost / outline Button ── -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="BorderBrush"     Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2B55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger (icon) Button ── -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#F87171"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D1515"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Nav Radio Button ── -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="#7A82B0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Margin"      Value="0,2"/>
            <Setter Property="GroupName"   Value="Navigation"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="NavBorder" Background="Transparent"
                                CornerRadius="8" Margin="10,2" Padding="12,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}"   FontSize="16" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Content}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#1A1F35"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#312E81"/>
                                <Setter Property="Foreground" Value="#C7D2FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── NEXUS-style Card ── -->
        <Style x:Key="ModuleCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ── Dark Text Input ── -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="BorderBrush"     Value="#2A3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="#0B1120"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Color Swatch Radio Button ── -->
        <Style x:Key="ColorSwatchStyle" TargetType="RadioButton">
            <Setter Property="GroupName"   Value="NoteColor"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Margin"      Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Outer" Width="26" Height="26" CornerRadius="13"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="3">
                            <Ellipse x:Name="Inner" Width="9" Height="9"
                                     Fill="White" Opacity="0"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Inner" Property="Opacity" Value="1"/>
                                <Setter TargetName="Outer" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Outer" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListView item reset ── -->
        <Style x:Key="CleanListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════ -->
        <!-- SIDEBAR  (NEXUS-style)                     -->
        <!-- ══════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="{StaticResource SidebarBgBrush}"
                BorderBrush="#1E293B" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo – horizontal, like NEXUS ─────────────────── -->
                <Border DockPanel.Dock="Top" Padding="18,20,18,18"
                        BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="8"
                                Background="#312E81">
                            <TextBlock Text="🗒" FontSize="17"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="OmniNote" Foreground="#F1F5F9" FontSize="16"
                                   FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Section label ──────────────────────────────────── -->
                <TextBlock DockPanel.Dock="Top" Text="MODULES"
                           Foreground="#334155" FontSize="10" FontWeight="Bold"
                           Margin="20,16,0,6"/>

                <!-- Nav items ──────────────────────────────────────── -->
                <StackPanel DockPanel.Dock="Top">
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Dashboard" Tag="⊞"
                                 IsChecked="True" Checked="NavDashboard_Checked"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Calendar" Tag="◫"
                                 Checked="NavCalendar_Checked"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Notes" Tag="✎"
                                 Checked="NavNotes_Checked"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Lists" Tag="☑"
                                 Checked="NavList_Checked"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Long Text" Tag="☰"
                                 Checked="NavLongText_Checked"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════ -->
        <!-- MAIN CONTENT AREA                         -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top header bar – NEXUS style ──────────── -->
            <Border Grid.Row="0" Background="#1E293B"
                    BorderBrush="#334155" BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid Height="56">
                    <TextBlock x:Name="PageTitle" Text="Dashboard"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#F1F5F9" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Scrollable panel area -->
            <ScrollViewer Grid.Row="1" Padding="20,16"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                <Grid>

                    <!-- ════════════════════════════════ -->
                    <!-- DASHBOARD                        -->
                    <!-- ════════════════════════════════ -->
                    <StackPanel x:Name="PanelDashboard" Visibility="Visible">
                        <TextBlock Text="Good to see you. Here's your overview."
                                   FontSize="13" Foreground="#64748B" Margin="0,0,0,16"/>

                        <!-- Stat cards -->
                        <UniformGrid Columns="3" Margin="0,0,0,16">
                            <Border Style="{StaticResource ModuleCardStyle}" Margin="0,0,8,0"
                                    BorderBrush="#818CF8" BorderThickness="0,3,0,0">
                                <StackPanel>
                                    <TextBlock Text="📅  Events" FontSize="12" Foreground="#94A3B8"/>
                                    <TextBlock x:Name="TxtEventCount" Text="0"
                                               FontSize="32" FontWeight="Bold"
                                               Foreground="#F1F5F9" Margin="0,4,0,0"/>
                                    <TextBlock Text="total scheduled" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ModuleCardStyle}" Margin="4,0"
                                    BorderBrush="#34D399" BorderThickness="0,3,0,0">
                                <StackPanel>
                                    <TextBlock Text="✅  Tasks" FontSize="12" Foreground="#94A3B8"/>
                                    <TextBlock x:Name="TxtTaskCount" Text="0"
                                               FontSize="32" FontWeight="Bold"
                                               Foreground="#F1F5F9" Margin="0,4,0,0"/>
                                    <TextBlock Text="still pending" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ModuleCardStyle}" Margin="8,0,0,0"
                                    BorderBrush="#FBBF24" BorderThickness="0,3,0,0">
                                <StackPanel>
                                    <TextBlock Text="📝  Notes" FontSize="12" Foreground="#94A3B8"/>
                                    <TextBlock x:Name="TxtNoteCount" Text="0"
                                               FontSize="32" FontWeight="Bold"
                                               Foreground="#F1F5F9" Margin="0,4,0,0"/>
                                    <TextBlock Text="saved" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Quick-start tips -->
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Quick Start" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#F1F5F9" Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#273348" CornerRadius="8" Padding="14" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="📅" FontSize="22"/>
                                            <TextBlock Text="Calendar" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#F1F5F9" Margin="0,6,0,3"/>
                                            <TextBlock Text="Click a day on the calendar to schedule events."
                                                       FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#0A2218" CornerRadius="8" Padding="14" Margin="3,0">
                                        <StackPanel>
                                            <TextBlock Text="📝" FontSize="22"/>
                                            <TextBlock Text="Notes" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#F1F5F9" Margin="0,6,0,3"/>
                                            <TextBlock Text="Create color-coded notes to organize ideas."
                                                       FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#221A08" CornerRadius="8" Padding="14" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="✅" FontSize="22"/>
                                            <TextBlock Text="Lists" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#F1F5F9" Margin="0,6,0,3"/>
                                            <TextBlock Text="Make multiple task lists with High/Medium/Low priority."
                                                       FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════════════════════════════════ -->
                    <!-- CALENDAR                         -->
                    <!-- ════════════════════════════════ -->
                    <StackPanel x:Name="PanelCalendar" Visibility="Collapsed">

                        <!-- Month navigation -->
                        <Border Style="{StaticResource ModuleCardStyle}" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content=" ◀ "
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="10,6" Click="BtnPrevMonth_Click"/>
                                <TextBlock x:Name="TxtMonthYear" Grid.Column="1"
                                           FontSize="17" FontWeight="Bold" Foreground="#F1F5F9"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content=" ▶ "
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="10,6" Click="BtnNextMonth_Click"/>
                            </Grid>
                        </Border>

                        <!-- Month grid -->
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <!-- Day-of-week labels -->
                                <UniformGrid Columns="7" Margin="0,0,0,4">
                                    <TextBlock Text="Sun" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4"/>
                                    <TextBlock Text="Mon" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4"/>
                                    <TextBlock Text="Tue" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4"/>
                                    <TextBlock Text="Wed" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4"/>
                                    <TextBlock Text="Thu" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4"/>
                                    <TextBlock Text="Fri" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4"/>
                                    <TextBlock Text="Sat" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4"/>
                                </UniformGrid>
                                <!-- Day cells — filled from code-behind BuildCalendarGrid() -->
                                <UniformGrid x:Name="CalendarDayGrid" Columns="7"/>
                            </StackPanel>
                        </Border>

                        <!-- Selected-day / range event panel (hidden until a day is clicked) -->
                        <Border x:Name="PanelSelectedDay"
                                Style="{StaticResource ModuleCardStyle}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="📅 " FontSize="14"/>
                                        <TextBlock x:Name="TxtSelectedDate"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                                    </StackPanel>
                                    <Button Content="✕ Deselect" Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Right" FontSize="11" Padding="10,5"
                                            Click="BtnDeselectDay_Click"/>
                                </Grid>

                                <!-- Range hint -->
                                <TextBlock x:Name="TxtRangeHint"
                                           Text="Click a second date on the calendar to select a range."
                                           FontSize="11" Foreground="#64748B" Margin="0,0,0,12"
                                           Visibility="Visible"/>

                                <!-- Event name -->
                                <TextBlock Text="Event Name" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtEventName" Style="{StaticResource InputStyle}"
                                         Height="36" VerticalContentAlignment="Center"
                                         Margin="0,0,0,10"/>

                                <!-- Optional note link -->
                                <TextBlock Text="Link to a Note  (optional)" FontSize="11"
                                           Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CboEventNote" Grid.Column="0"
                                              DisplayMemberPath="Note.name"
                                              FontSize="13" Padding="8,7"
                                              Margin="0,0,8,0" Height="36"
                                              BorderBrush="#334155"/>
                                    <Button Grid.Column="1" Content="＋ Add Event"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="BtnAddEvent_Click"/>
                                </Grid>
                                <TextBlock x:Name="TxtCalendarValidation"
                                           Foreground="{StaticResource ErrorBrush}"
                                           FontSize="12" Margin="0,0,0,8" Visibility="Collapsed"/>

                                <!-- Events for selected day/range -->
                                <ItemsControl x:Name="IcDayEvents">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#273348" CornerRadius="7"
                                                    Padding="12,8" Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                                             Fill="{StaticResource PrimaryBrush}"
                                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="13" Foreground="#F1F5F9"/>
                                                        <TextBlock Text="{Binding DateLabel}"
                                                                   FontSize="10" Foreground="#64748B"
                                                                   Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                    <!-- Note badge -->
                                                    <Border Grid.Column="2" Background="#1E3A5F"
                                                            CornerRadius="4" Padding="5,2" Margin="6,0"
                                                            Visibility="{Binding NoteBadgeVisibility}">
                                                        <TextBlock Text="📝 note" FontSize="10"
                                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                                    </Border>
                                                    <Button Grid.Column="3" Content="🗑"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Tag="{Binding}" Click="BtnDeleteEvent_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="TxtNoEvents"
                                           Text="No events for this selection — add one above."
                                           Foreground="#64748B" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,10"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- All events list -->
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <TextBlock Text="All Events" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#F1F5F9" Margin="0,0,0,12"/>
                                <ItemsControl x:Name="IcAllEvents">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FAFBFF" CornerRadius="7"
                                                    Padding="12,8" Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#1E3A5F"
                                                            CornerRadius="5" Padding="8,3" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding DateLabel}" FontSize="11"
                                                                   Foreground="{StaticResource PrimaryBrush}"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                               FontSize="13" Foreground="#F1F5F9"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="🗑"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Tag="{Binding}" Click="BtnDeleteEvent_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="TxtAllEventsEmpty"
                                           Text="No events yet — click a day above to add one."
                                           Foreground="#64748B" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,16"
                                           Visibility="Visible"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════════════════════════════════ -->
                    <!-- NOTES                            -->
                    <!-- ════════════════════════════════ -->
                    <StackPanel x:Name="PanelNotes" Visibility="Collapsed">

                        <!-- Create note -->
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <TextBlock Text="New Note" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#F1F5F9" Margin="0,0,0,14"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Note name -->
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Name" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtNoteName" Style="{StaticResource InputStyle}"
                                                 Height="36" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <!-- Note description -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Description (optional)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtNoteDesc" Style="{StaticResource InputStyle}"
                                                 Height="36" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Color picker -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,16" VerticalAlignment="Center">
                                    <TextBlock Text="Color:" FontSize="12" Foreground="#94A3B8"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="RbColorIndigo" Style="{StaticResource ColorSwatchStyle}" Background="#5B6AF0" IsChecked="True"/>
                                    <RadioButton x:Name="RbColorRed"    Style="{StaticResource ColorSwatchStyle}" Background="#E74C3C"/>
                                    <RadioButton x:Name="RbColorOrange" Style="{StaticResource ColorSwatchStyle}" Background="#F39C12"/>
                                    <RadioButton x:Name="RbColorGreen"  Style="{StaticResource ColorSwatchStyle}" Background="#27AE60"/>
                                    <RadioButton x:Name="RbColorTeal"   Style="{StaticResource ColorSwatchStyle}" Background="#1ABC9C"/>
                                    <RadioButton x:Name="RbColorPurple" Style="{StaticResource ColorSwatchStyle}" Background="#9B59B6"/>
                                </StackPanel>

                                <Button Content="💾  Add Note"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Click="BtnSaveNote_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Notes list -->
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Saved Notes" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#F1F5F9" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtNoteCountBadge" FontSize="12"
                                               Foreground="#64748B" HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <ItemsControl x:Name="IcNotes">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- NEXUS-style note row -->
                                            <Border Background="#273348" CornerRadius="8"
                                                    Margin="0,3" BorderBrush="#334155" BorderThickness="1"
                                                    Padding="14,11">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Colored icon box -->
                                                    <Border Grid.Column="0" Width="36" Height="36"
                                                            Background="{Binding ColorBrush}"
                                                            CornerRadius="8" Margin="0,0,12,0"
                                                            Opacity="0.85">
                                                        <TextBlock Text="📝" FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <!-- Text + module badges -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Note.name}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   Foreground="#F1F5F9"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11" Foreground="#94A3B8"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0"
                                                                   Visibility="{Binding DescriptionVisibility}"/>
                                                        <TextBlock Text="{Binding ModuleAssignments}"
                                                                   FontSize="10" Foreground="#6366F1"
                                                                   Margin="0,3,0,0"
                                                                   Visibility="{Binding ModuleBadgeVisibility}"/>
                                                    </StackPanel>
                                                    <!-- Edit -->
                                                    <Button Grid.Column="2" Content="✏"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Tag="{Binding}" Click="BtnEditNote_Click"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,4,0" Padding="8,5" FontSize="13"/>
                                                    <!-- Delete -->
                                                    <Button Grid.Column="3" Content="🗑"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Tag="{Binding}" Click="BtnDeleteNote_Click"
                                                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="TxtNoNotes"
                                           Text="No notes yet — create one above."
                                           Foreground="#64748B" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,16"
                                           Visibility="Visible"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════════════════════════════════ -->
                    <!-- LISTS                            -->
                    <!-- ════════════════════════════════ -->
                    <StackPanel x:Name="PanelList" Visibility="Collapsed">

                        <!-- List selector bar -->
                        <Border Style="{StaticResource ModuleCardStyle}" Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CboLists" Grid.Column="0"
                                          FontSize="14" FontWeight="SemiBold"
                                          Padding="10,8" Margin="0,0,10,0"
                                          BorderBrush="#334155"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="CboLists_SelectionChanged"/>
                                <Button Grid.Column="1" Content="＋ New List"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,0" Click="BtnNewList_Click"/>
                                <Button Grid.Column="2" Content="🗑 Delete"
                                        Style="{StaticResource DangerButtonStyle}"
                                        FontSize="12" Padding="10,7"
                                        BorderBrush="#4D1A1A" BorderThickness="1"
                                        Click="BtnDeleteList_Click"/>
                            </Grid>
                        </Border>

                        <!-- New-list name input (hidden by default) -->
                        <Border x:Name="PanelNewList"
                                Style="{StaticResource ModuleCardStyle}"
                                Padding="16,14" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtNewListName" Style="{StaticResource InputStyle}"
                                         Margin="0,0,8,0" Height="36" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="Create"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,6,0" Click="BtnCreateList_Click"/>
                                <Button Grid.Column="2" Content="Cancel"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Click="BtnCancelNewList_Click"/>
                            </Grid>
                        </Border>

                        <!-- Add task -->
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Add Task" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#F1F5F9" Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtNewTask" Grid.Column="0"
                                             Style="{StaticResource InputStyle}"
                                             Margin="0,0,8,0" Height="36"
                                             VerticalContentAlignment="Center"/>
                                    <!-- Priority label + dropdown stacked -->
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Priority" FontSize="10" FontWeight="Bold"
                                                   Foreground="#64748B" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CboPriority" FontSize="13"
                                                  Padding="8,7" SelectedIndex="0">
                                            <ComboBoxItem Content="None"/>
                                            <ComboBoxItem Content="High"/>
                                            <ComboBoxItem Content="Medium"/>
                                            <ComboBoxItem Content="Low"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="＋ Add Task"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            VerticalAlignment="Bottom"
                                            Click="BtnAddTask_Click"/>
                                </Grid>
                                <TextBlock x:Name="TxtTaskValidation"
                                           Foreground="{StaticResource ErrorBrush}"
                                           FontSize="12" Margin="0,8,0,0"
                                           Visibility="Collapsed"/>

                                <!-- Add existing note to this list (§2.2.3.2) -->
                                <Border BorderBrush="#334155" BorderThickness="0,1,0,0"
                                        Margin="0,12,0,0" Padding="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Add existing note:" FontSize="12"
                                                   Foreground="#94A3B8" VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <ComboBox x:Name="CboExistingNote" Grid.Column="1"
                                                  DisplayMemberPath="Note.name"
                                                  FontSize="13" Padding="8,6" Height="34"
                                                  BorderBrush="#334155"
                                                  Margin="0,0,8,0"
                                                  DropDownOpened="CboExistingNote_DropDownOpened"/>
                                        <Button Grid.Column="2" Content="＋ Add to List"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Click="BtnAddExistingNote_Click"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Task list -->
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Tasks" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#F1F5F9" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="Sort:" FontSize="12" Foreground="#94A3B8"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CboSort" FontSize="12" Padding="8,5"
                                                  BorderBrush="#334155" Width="170"
                                                  SelectionChanged="CboSort_SelectionChanged"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Default Order"/>
                                            <ComboBoxItem Content="Priority (High → Low)"/>
                                            <ComboBoxItem Content="Priority (Low → High)"/>
                                            <ComboBoxItem Content="Name A → Z"/>
                                            <ComboBoxItem Content="Date (Earliest → Latest)"/>
                                        </ComboBox>
                                        <TextBlock x:Name="TxtTaskCountBadge" FontSize="12"
                                                   Foreground="#64748B"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <ListView x:Name="LvTasks"
                                          BorderThickness="0" Background="Transparent"
                                          ItemContainerStyle="{StaticResource CleanListItemStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E293B" CornerRadius="8"
                                                    Margin="0,2" BorderBrush="#334155"
                                                    BorderThickness="1" Padding="14,11">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsComplete}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"
                                                              Click="ChkTask_Click"/>
                                                    <!-- Priority pill (NEXUS-style) -->
                                                    <Border Grid.Column="1"
                                                            Background="{Binding PriorityBackground}"
                                                            CornerRadius="4" Padding="7,2"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,12,0"
                                                            Visibility="{Binding PriorityVisible}">
                                                        <TextBlock Text="{Binding PriorityMarker}"
                                                                   Foreground="{Binding PriorityColor}"
                                                                   FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding TaskName}"
                                                               FontSize="13" VerticalAlignment="Center"
                                                               Foreground="#F1F5F9">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                        <Setter Property="Foreground"      Value="#9CA3AF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Reorder (§2.2.3.3) -->
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                VerticalAlignment="Center" Margin="6,0">
                                                        <Button Content="▲"
                                                                Style="{StaticResource GhostButtonStyle}"
                                                                Tag="{Binding}" Click="BtnMoveTaskUp_Click"
                                                                Padding="4,2" FontSize="10" Width="22"
                                                                ToolTip="Move up (only in Default Order)"/>
                                                        <Button Content="▼"
                                                                Style="{StaticResource GhostButtonStyle}"
                                                                Tag="{Binding}" Click="BtnMoveTaskDown_Click"
                                                                Padding="4,2" FontSize="10" Width="22"
                                                                ToolTip="Move down (only in Default Order)"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="4" Content="🗑"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Tag="{Binding}" Click="BtnDeleteTask_Click"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock x:Name="TxtNoTasks"
                                           Text="No tasks yet — add one above."
                                           Foreground="#64748B" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,16"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════════════════════════════════ -->
                    <!-- LONG TEXT                        -->
                    <!-- ════════════════════════════════ -->
                    <StackPanel x:Name="PanelLongText" Visibility="Collapsed">
                        <Grid MinHeight="540">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── Left: document list ── -->
                            <Border Style="{StaticResource ModuleCardStyle}" Margin="0,0,8,0">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <TextBlock Text="Documents" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#F1F5F9" Margin="0,0,0,10"/>

                                        <!-- Inline new-doc name entry (hidden by default) -->
                                        <Border x:Name="PanelNewLtDoc" Visibility="Collapsed" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBox x:Name="TxtNewLtDocName"
                                                         Style="{StaticResource InputStyle}"
                                                         Height="32" VerticalContentAlignment="Center"
                                                         Margin="0,0,0,6"
                                                         KeyDown="TxtNewLtDocName_KeyDown"/>
                                                <TextBlock x:Name="TxtLtDocValidation"
                                                           Foreground="{StaticResource ErrorBrush}"
                                                           FontSize="11" Margin="0,0,0,4"
                                                           Visibility="Collapsed"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="Create"
                                                            Style="{StaticResource PrimaryButtonStyle}"
                                                            Margin="0,0,4,0"
                                                            Click="BtnCreateLtDoc_Click"/>
                                                    <Button Grid.Column="1" Content="✕"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Padding="8,5"
                                                            Click="BtnCancelLtDoc_Click"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Button Content="＋ New Document"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                HorizontalAlignment="Stretch"
                                                Click="BtnNewLongText_Click"/>
                                    </StackPanel>

                                    <!-- Document list -->
                                    <ListBox x:Name="LbLtDocuments"
                                             BorderThickness="0" Background="Transparent"
                                             SelectionChanged="LbLtDocuments_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding"    Value="8,6"/>
                                                <Setter Property="Margin"     Value="0,2"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="#1A2045"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#222840"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Title}"
                                                               FontSize="12" Foreground="#F1F5F9"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="1" Content="🗑"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Tag="{Binding}"
                                                            Click="BtnDeleteLtDoc_Click"
                                                            Padding="4,3" FontSize="11"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <!-- ── Right: editor pane ── -->
                            <Border Grid.Column="1" Style="{StaticResource ModuleCardStyle}">
                                <Grid>
                                    <!-- Placeholder when nothing selected -->
                                    <TextBlock x:Name="TxtLtPlaceholder"
                                               Text="Select or create a document to start editing."
                                               Foreground="#64748B" FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- Full editor (shown when a doc is active) -->
                                    <DockPanel x:Name="PanelLtEditor" Visibility="Collapsed">

                                        <!-- Title / rename row -->
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="TxtLtTitle"
                                                     FontSize="15" FontWeight="SemiBold"
                                                     BorderBrush="#334155" BorderThickness="1"
                                                     Padding="8,6" Height="36"
                                                     VerticalContentAlignment="Center"
                                                     Margin="0,0,8,0"
                                                     LostFocus="TxtLtTitle_LostFocus"
                                                     KeyDown="TxtLtTitle_KeyDown"/>
                                            <TextBlock Grid.Column="1" Text="rename ↵"
                                                       FontSize="10" Foreground="#64748B"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Formatting + annotation toolbar -->
                                        <Border DockPanel.Dock="Top" Background="#273348"
                                                CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Bold -->
                                                <Button x:Name="BtnLtBold"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Height="30" Padding="12,5"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Make selected text Bold (Ctrl+B)"
                                                        Click="BtnLtBold_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="B" FontWeight="Bold"
                                                                   FontSize="13" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" Bold" FontSize="11"
                                                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <!-- Italic -->
                                                <Button x:Name="BtnLtItalic"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Height="30" Padding="12,5"
                                                        Margin="0,0,16,0"
                                                        ToolTip="Make selected text Italic (Ctrl+I)"
                                                        Click="BtnLtItalic_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="I" FontStyle="Italic"
                                                                   FontSize="13" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" Italic" FontSize="11"
                                                                   Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <!-- Divider -->
                                                <Border Width="1" Height="20" Background="#334155"
                                                        VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                <!-- Note picker + assign -->
                                                <ComboBox x:Name="CboLtNote"
                                                          DisplayMemberPath="Note.name"
                                                          FontSize="12" Padding="8,5"
                                                          Width="160" Height="30"
                                                          Margin="0,0,8,0"
                                                          ToolTip="Choose a note to link to selected text"/>
                                                <Button Content="🔗  Assign Note to Selection"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Height="30" Padding="12,5" FontSize="12"
                                                        ToolTip="Highlights the selected text and links it to the chosen note"
                                                        Click="BtnLtAssignNote_Click"/>
                                                <!-- Hidden controls kept for code-behind compatibility -->
                                                <TextBox x:Name="TxtLtRegex" Visibility="Collapsed"/>
                                                <Button x:Name="BtnLtToggleHighlights"
                                                        Visibility="Collapsed"
                                                        Click="BtnLtToggleHighlights_Click"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Inline validation -->
                                        <TextBlock x:Name="TxtLtValidation"
                                                   DockPanel.Dock="Top"
                                                   Foreground="{StaticResource ErrorBrush}"
                                                   FontSize="12" Margin="0,0,0,6"
                                                   Visibility="Collapsed"/>

                                        <!-- Rich text editor -->
                                        <RichTextBox x:Name="RtbEditor"
                                                     FontSize="13" Padding="10"
                                                     BorderBrush="#334155" BorderThickness="1"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     MinHeight="320"
                                                     AcceptsReturn="True"
                                                     TextChanged="RtbEditor_TextChanged"/>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════ -->
        <!-- STATUS BAR                                 -->
        <!-- ══════════════════════════════════════════ -->
        <Border x:Name="StatusBar" Grid.Column="1" Grid.Row="1"
                Background="{StaticResource SuccessBrush}"
                Padding="20,10" Visibility="Collapsed" CornerRadius="0,0,0,0">
            <Grid>
                <TextBlock x:Name="TxtStatus" Foreground="White"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="✕" Background="Transparent" Foreground="#F1F5F9"
                        BorderThickness="0" FontSize="14" HorizontalAlignment="Right"
                        Cursor="Hand" Click="BtnDismissStatus_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>